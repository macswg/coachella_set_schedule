# Google Sheets Configuration
# Set to true to use Google Sheets instead of in-memory mock data
USE_GOOGLE_SHEETS=false

# Get the spreadsheet ID from the URL: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
GOOGLE_SHEETS_ID=your-spreadsheet-id-here

# Which tab/worksheet to use (leave empty for first sheet)
GOOGLE_SHEET_TAB=

# Path to your Google Cloud service account JSON key file
GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json

# App Configuration
STAGE_NAME=Main Stage
TIMEZONE=America/Los_Angeles

# Server Configuration
HOST=0.0.0.0
PORT=3030

# Multi-Show Configuration
# Comma-separated list of Google Sheet tabs in show order. Leave empty for single-show mode.
# Example: SHOW_TABS=W1Shw1,W1Shw2,W1Shw3
SHOW_TABS=

# Ki Pro Recorder Configuration
# IP address of the AJA Ki Pro Rack
KIPRO_IP=

# Recording Trigger Configuration
# Set to true to enable automatic recording triggers
RECORDING_ENABLED=false
# Minutes before scheduled start to trigger recording
RECORDING_PRE_START_MINUTES=5
# Only trigger recording for acts whose names start with this prefix (empty = all acts)
# Example: RECORDING_ACT_PREFIX=Set:
RECORDING_ACT_PREFIX=

# Art-Net Configuration
# Enable Art-Net DMX receiver for brightness control
ARTNET_ENABLED=false
ARTNET_PORT=6454
ARTNET_UNIVERSE=0
# Bit depth: 8 for single-channel (0-255), 16 for high/low byte pair (0-65535)
ARTNET_BIT_DEPTH=8
# 8-bit mode: single DMX channel
ARTNET_CHANNEL=1
# 16-bit mode: two DMX channels (high byte, low byte)
ARTNET_CHANNEL_HIGH=1
ARTNET_CHANNEL_LOW=2
# Maximum nits output of the LED wall at full brightness (varies per display)
ARTNET_MAX_NITS=11000
